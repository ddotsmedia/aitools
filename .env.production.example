# AI Tools Hub — Production Environment
# Copy to .env.production and fill in all values

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=hub
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=aitoolshub
# Internal Docker network URL (postgres service name)
DATABASE_URL=postgresql://hub:CHANGE_ME_strong_password@postgres:5432/aitoolshub?schema=public

# ── Redis (internal Docker network) ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=CHANGE_ME_32_char_min_secret_key

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Public URLs (change to real domain) ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aitoolshub.ddotsmedia.com
NEXT_PUBLIC_API_URL=https://aitoolshub.ddotsmedia.com/api
